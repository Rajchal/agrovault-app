{
  "expo": {
    "name": "AgroVault",
    "slug": "agrovault-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "bundleIdentifier": "com.agrovault.mobile",
      "buildNumber": "1",
      "infoPlist": {
        "NSAppTransportSecurity": {
          "NSAllowsArbitraryLoads": true
        }
      }
    },
    "android": {
      "package": "com.agrovault.mobile",
      "versionCode": 1
    },
    "scheme": "agrovault",
    "plugins": [
      "./plugins/withCleartextTraffic"
    ],
    "extra": {
      "eas": {
        "projectId": "648f34ed-91e3-48c6-85e0-4b660e1da0ff"
      }
    }
  }
}